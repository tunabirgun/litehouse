{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Litehouse",
  "version": "0.1.0-alpha.1",
  "identifier": "io.github.tunabirgun.litehouse",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:4173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../web/dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; base-uri 'none'; connect-src 'self' ipc: http://ipc.localhost; font-src 'self' data:; form-action 'self'; frame-src 'none'; img-src 'self' blob: data:; object-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; worker-src 'self' blob:",
      "devCsp": "default-src 'self'; base-uri 'none'; connect-src 'self' ipc: http://ipc.localhost ws://127.0.0.1:4173; font-src 'self' data:; form-action 'self'; frame-src 'none'; img-src 'self' blob: data:; object-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; worker-src 'self' blob:",
      "freezePrototype": true
    },
    "windows": [
      {
        "label": "main",
        "title": "Litehouse",
        "width": 1440,
        "height": 940,
        "minWidth": 960,
        "minHeight": 680,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "useHttpsScheme": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "category": "Education",
    "copyright": "Copyright © 2026 Tuna Birgün",
    "shortDescription": "Evidence-locked literature surveillance",
    "longDescription": "Local-first literature discovery, reading, evidence review, and research reporting.",
    "externalBin": ["binaries/litehouse-backend"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "webviewInstallMode": { "type": "embedBootstrapper" },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": true,
        "languages": ["English", "Turkish"]
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/tunabirgun/litehouse/releases/download/updater/latest.json"
      ],
      "pubkey": "__LITEHOUSE_TAURI_UPDATER_PUBLIC_KEY__",
      "windows": { "installMode": "basicUi" },
      "dangerousInsecureTransportProtocol": false
    }
  }
}
