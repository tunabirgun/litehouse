{
  "name": "litehouse-workspace",
  "private": true,
  "version": "0.1.0-alpha.1",
  "workspaces": [
    "web"
  ],
  "scripts": {
    "build": "npm --workspace web run build",
    "desktop:dev": "tauri dev",
